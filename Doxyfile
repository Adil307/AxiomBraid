# =============================================================================
# AxiomBraid 2.0.0 — Final Doxygen Configuration
#
# Generate locally:
#   Windows CMD/PowerShell: generate_doxygen.cmd
#   Direct:                doxygen Doxyfile
#
# Generated HTML:
#   docs/doxygen/html/index.html
# =============================================================================

# Project identity
PROJECT_NAME           = "AxiomBraid"
PROJECT_NUMBER         = "2.0.0"
PROJECT_BRIEF          = "Explainable, safety-first data quality inspection, validation, cleaning, evaluation, and reporting framework."
OUTPUT_DIRECTORY       = docs/doxygen
OUTPUT_LANGUAGE        = English
ALLOW_UNICODE_NAMES    = YES

# Main page and source inputs
USE_MDFILE_AS_MAINPAGE = README.md
INPUT                  = src/axiombraid \
                         README.md \
                         docs
FILE_PATTERNS          = *.py \
                         *.md
RECURSIVE              = YES
INPUT_ENCODING         = UTF-8
EXTENSION_MAPPING      = py=Python

# Exclusions
EXCLUDE                = docs/doxygen \
                         src/axiombraid.egg-info \
                         build \
                         dist \
                         .venv \
                         venv
EXCLUDE_PATTERNS       = */__pycache__/* \
                         */.git/* \
                         */.github/* \
                         */.pytest_cache/* \
                         */.mypy_cache/* \
                         */.ruff_cache/* \
                         */build/* \
                         */dist/* \
                         */*.egg-info/*

# Examples
EXAMPLE_PATH           = examples
EXAMPLE_PATTERNS       = *.py
EXAMPLE_RECURSIVE      = YES

# Python / Markdown extraction
PYTHON_DOCSTRING       = YES
MARKDOWN_SUPPORT       = YES
TOC_INCLUDE_HEADINGS   = 5
AUTOLINK_SUPPORT       = YES
JAVADOC_AUTOBRIEF      = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_PACKAGE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_LOCAL_METHODS  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
SHOW_FILES             = YES
SHOW_NAMESPACES        = YES
SHOW_USED_FILES        = YES
SORT_MEMBER_DOCS       = YES
SORT_MEMBERS_CTORS_1ST = YES
GENERATE_TODOLIST      = YES
GENERATE_TESTLIST      = YES
GENERATE_BUGLIST       = YES
GENERATE_DEPRECATEDLIST= YES

# Paths and source browser
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = .
STRIP_FROM_INC_PATH    = src
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
REFERENCES_LINK_SOURCE = YES
SOURCE_TOOLTIPS        = YES
VERBATIM_HEADERS       = YES

# Diagnostics
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_IF_INCOMPLETE_DOC = YES
WARN_NO_PARAMDOC       = NO
WARN_AS_ERROR          = NO
WARN_FORMAT            = "$file:$line: $text"
WARN_LOGFILE           = docs/doxygen/doxygen-warnings.log

# Preprocessing
ENABLE_PREPROCESSING   = YES
SEARCH_INCLUDES        = YES
INCLUDE_PATH           = src
SKIP_FUNCTION_MACROS   = YES

# HTML output
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_DYNAMIC_MENUS     = YES
HTML_DYNAMIC_SECTIONS  = YES
GENERATE_TREEVIEW      = YES
TREEVIEW_WIDTH         = 300
SEARCHENGINE           = YES
DISABLE_INDEX          = NO

# Other output formats
GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO
GENERATE_DOCBOOK       = NO

# Graphviz diagrams
HAVE_DOT               = YES
DOT_NUM_THREADS        = 0
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
GROUP_GRAPHS           = YES
UML_LOOK               = YES
UML_LIMIT_NUM_FIELDS   = 50
TEMPLATE_RELATIONS     = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
GRAPHICAL_HIERARCHY    = YES
DIRECTORY_GRAPH        = YES
DIR_GRAPH_MAX_DEPTH    = 3
DOT_GRAPH_MAX_NODES    = 100
MAX_DOT_GRAPH_DEPTH    = 0
DOT_CLEANUP            = YES
GENERATE_LEGEND        = YES

# Tag file for external cross-referencing
GENERATE_TAGFILE       = docs/doxygen/axiombraid-2.0.0.tag
